{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/test-results", "destination": "/api/index" },
    {
      "source": "/api/test-results/(.*)",
      "destination": "/api/test-results/$1"
    },
    { "source": "/api/recent-failures", "destination": "/api/recent-failures" },
    {
      "source": "/api/tab-performance/(.*)",
      "destination": "/api/tab-performance/$1"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "VITE_SUPABASE_URL": "@vite_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@vite_supabase_anon_key"
  }
}
